NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Telegram bot (create via @BotFather, paste the token here)
TELEGRAM_BOT_TOKEN=

# Public app URL used in Telegram "View Task" deep links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for Supabase Database Webhook (optional but recommended).
# If set, the webhook endpoint requires a matching x-webhook-secret header.
# Configure the same value in Supabase Dashboard → Database → Webhooks → Headers.
WEBHOOK_SECRET=

# Shared secret for /api/cleanup endpoint (recommended).
# cron-job.org should send this value in the x-cleanup-secret header.
CLEANUP_SECRET=

# Secret used to sign session tokens (required in production).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Google Drive (for attendance photos)
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable Google Drive API
# 3. Create a Service Account → download JSON key
# 4. Create a folder "TuTrack-Attendance" in your Google Drive
# 5. Share the folder with the service account email (Editor access)
# 6. Set folder ID from: https://drive.google.com/drive/folders/FOLDER_ID
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

